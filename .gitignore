# Historical Windows binaries and build outputs are preserved locally only.
_backup/
# Working material for the source hunt (encrypted RARs, mail zips, ILYATRIS, etc.)
_research/
# Dropbox sync-conflict duplicate of src/
src Rem=error!/
.DS_Store

# Build artifacts (the buildable sources live in src/)
*.exe
*.dll
*.dcu
*.gid
*.GID
*.hlp
*.HLP

# The historical release archive release/hookdump.zip is tracked on purpose;
# do not add a blanket *.zip ignore here.

# versions/ — the historical version history (v1.5 … v2.8) is published openly,
# including the period release binaries; re-include it despite the rules above.
!versions/
!versions/**
# ...but still never track macOS junk inside it
.DS_Store
versions/**/.DS_Store
